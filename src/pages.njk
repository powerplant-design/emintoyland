---
pagination:
  data: kirby.all
  size: 1
  alias: page
permalink: "/{% if page.uri != 'home' %}{{ page.uri }}/{% endif %}index.html"
layout: base.njk
---

{% if page.parentSlug == "work" %}
  {% set title = page.title %}
  {% set image = page.workHeroImage if page.workHeroImage else page.workImage %}
  {% set imageAlt = page.title %}
  {% set date = page.publishedDate %}
  {% set updated = page.modifiedDate %}
  {% set backLink = "/work/" %}
  {% set backLabel = "< Back to Work" %}
  {% set body = (page.body if page.body else page.text) %}
  {% set externalLink = page.workLink %}
  {% set externalLinkLabel = page.workLinkLabel %}
  {% set badges = [page.workType] %}
  {% include "components/article-detail.njk" %}

{% elif page.uri == "home" %}
  {% include "components/hero-splash.njk" %}
  {% set title = "" %}
  {% set heroTagline = page.heroHeading %}
  {% set body = page.heroText %}
  {% set imageSrc = page.heroImage %}
  {% set imageAlt = page.heroImageAlt %}
  {% set loading = "eager" %}
  {% set ctaText = page.heroCtaText %}
  {% set ctaLink = page.heroCtaLink %}
  {% include "components/hero-home.njk" %}
  {% include "components/showcase-cards.njk" %}
  {% set heading = page.aboutHeading %}
  {% set text = page.aboutText %}
  {% set imageSrc = page.aboutImage %}
  {% set imageAlt = page.aboutImageAlt %}
  {% set imageSide = "right" %}
  {% set ctaText = page.aboutCtaText %}
  {% set ctaLink = page.aboutCtaLink %}
  {% include "components/split-section.njk" %}

{% elif page.uri == "work" %}
  <div class="section wrapper stack flow | text-align-center" style="--stack-horizontal: center;" data-space="xs">
    <h1>{{ page.heading if page.heading else page.title }}</h1>
    {% if page.text %}
      <p style="font-size: var(--step-0-1); max-width: var(--measure-medium);">{{ page.text }}</p>
    {% endif %}

    <div class="filter-tabs | cluster" style="--cluster-gap: var(--space-xs);" data-filter="tabs">
      <button class="filter-tabs__btn is-active" data-filter="all">ALL</button>
      <button class="filter-tabs__btn" data-filter="podcast">PODCASTS</button>
      <button class="filter-tabs__btn" data-filter="video">VIDEO</button>
      <button class="filter-tabs__btn" data-filter="writing">WRITING</button>
      <button class="filter-tabs__btn" data-filter="featured-in">FEATURED IN</button>
    </div>

    <div class="grid" data-layout="3col" data-filter="container" style="text-align: start;">
      {% for item in kirby.all %}{% if item.parentSlug == "work" %}
        <article class="card" data-filter="{{ item.workType | lower | replace(' ', '-') }}">
          <a href="/{{ item.uri }}/">
            <div class="card__image-wrap frame" style="--_ratio: 1/1;">
              {% if item.workImage %}
                <img src="{{ item.workImage }}" alt="{{ item.workImageAlt if item.workImageAlt else item.title }}" sizes="(min-width: 62rem) 33vw, 100vw">
              {% endif %}
              <span class="card__category">{{ item.workType }}</span>
            </div>
            <div class="card__body">
              <h2 class="card__title">{{ item.title }}</h2>
              <p class="card__excerpt">{{ item.text | striptags | truncate(120) }}</p>
            </div>
          </a>
        </article>{% endif %}{% endfor %}
    </div>
  </div>

{% elif page.parentSlug == "blog" %}
  {% set title = page.title %}
  {% set image = page.featuredImage %}
  {% set imageAlt = page.featuredImageAlt if page.featuredImageAlt else page.title %}
  {% set date = page.publishedDate %}
  {% set updated = page.modifiedDate %}
  {% set backLink = "/blog/" %}
  {% set backLabel = "‹ Back to Blog" %}
  {% set body = page.body %}
  {% set rawHtml = true %}
  {% set badges = page.tagArray %}
  {% include "components/article-detail.njk" %}

{% elif page.uri == "blog" %}
  <div class="section wrapper stack flow | text-align-center" data-space="xs" style="--stack-horizontal: center;">
    <h1>{{ page.heading if page.heading else page.title }}</h1>
    {% if page.text %}
      <p style="font-size: var(--step-0-1); max-width: var(--measure-medium);">{{ page.text }}</p>
    {% endif %}
    {% if kirby.blogTags | length %}
      <div class="filter-tabs | cluster" style="--cluster-gap: var(--space-xs);" data-filter="tabs" data-filter-type="blog">
        <button class="filter-tabs__btn is-active" data-filter="all">ALL</button>
        {% for tag in kirby.blogTags %}
          <button class="filter-tabs__btn" data-filter="{{ tag | replace(' ', '-') }}">{{ tag }}</button>
        {% endfor %}
      </div>
    {% endif %}
    <div class="grid" data-layout="3col" data-filter="container" data-filter-type="blog" style="text-align: start;">
      {% for item in kirby.all %}{% if item.parentSlug == "blog" %}
        <article class="card" data-filter="{{ item.tagsSlug }}">
          <a href="/{{ item.uri }}/">
            <div class="card__image-wrap frame" style="--_ratio: 1/1;">
              {% if item.featuredImage %}
                <img src="{{ item.featuredImage }}" alt="{{ item.featuredImageAlt if item.featuredImageAlt else item.title }}" sizes="(min-width: 62rem) 33vw, 100vw">
              {% endif %}
              {% if item.tags %}
                <div class="card__tags">
                  {% for tag in item.tags | split(',') %}
                    <span class="card__tag">{{ tag | trim }}</span>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
            <div class="card__body">
              {% if item.publishedDate %}
                <span class="card__date">{{ item.publishedDate | formatDateShort }}</span>
              {% endif %}
              <h2 class="card__title">{{ item.title }}</h2>
              {% if item.excerpt %}
                <p class="card__excerpt">{{ item.excerpt | striptags | truncate(120) }}</p>
              {% endif %}
            </div>
          </a>
        </article>{% endif %}{% endfor %}
    </div>
  </div>

{% elif page.uri == "about" %}
  {% if page.aboutIntroHeading or page.aboutIntroText %}
    {% set title = page.aboutIntroHeading %}
    {% set body = page.aboutIntroText %}
    {% set imageSrc = page.aboutIntroImage %}
    {% set imageAlt = page.aboutIntroHeading %}
    {% set loading = "eager" %}
    {% set ctaText = "" %}
    {% set ctaLink = "" %}
    {% include "components/hero-home.njk" %}
  {% endif %}

  {% if page.aboutCredentialsItems or page.aboutCredentialsHeading %}
    <section class="section">
      <div class="wrapper flow">
        {% if page.aboutCredentialsHeading %}
          <h2>{{ page.aboutCredentialsHeading }}</h2>
        {% endif %}
        <div class="grid" data-layout="2col">
          {% for item in page.aboutCredentialsItems %}
            <article class="credential">
              <div class="credential__logo">
                {% if item.logo %}
                  <img src="{{ item.logo.url }}" alt="{{ item.logo.alt }}" loading="lazy">
                {% endif %}
              </div>
              <div class="credential__body">
                {% if item.heading %}
                  <h3 class="credential__title">{{ item.heading }}</h3>
                {% endif %}
                {% if item.text %}
                  <p class="credential__text">{{ item.text }}</p>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  {% if page.aboutSupervisionItems or page.aboutSupervisionHeading %}
    <section class="section">
      <div class="wrapper flow">
        {% if page.aboutSupervisionHeading %}
          <h2>{{ page.aboutSupervisionHeading }}</h2>
        {% endif %}
        <div class="grid" data-layout="2col">
          {% for item in page.aboutSupervisionItems %}
            <article class="credential">
              <div class="credential__body" style="margin-inline-start: 0;">
                {% if item.heading %}
                  <h3 class="credential__title">{{ item.heading }}</h3>
                {% endif %}
                {% if item.text %}
                  <p class="credential__text">{{ item.text }}</p>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  {% if page.aboutSpecialiseItems or page.aboutSpecialiseHeading %}
    <section class="section specialise">
      <div class="wrapper flow">
        {% if page.aboutSpecialiseHeading %}
          <h2>{{ page.aboutSpecialiseHeading }}</h2>
        {% endif %}
        {% for item in page.aboutSpecialiseItems %}
          <p class="specialise__item" data-reveal>{{ item }}</p>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {% if page.aboutPodcastHeading or page.aboutPodcastText or page.aboutPodcastImage %}
    {% set heading = page.aboutPodcastHeading %}
    {% set text = page.aboutPodcastText %}
    {% set imageSrc = page.aboutPodcastImage %}
    {% set imageAlt = page.aboutPodcastImageAlt %}
    {% set imageSide = "right" %}
    {% set ctaText = page.aboutPodcastCtaText %}
    {% set ctaLink = page.aboutPodcastCtaLink %}
    {% include "components/split-section.njk" %}
  {% endif %}

{% elif page.uri == "thanks" %}
  <section class="section" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="wrapper flow text-align-center">
      <h1>{{ page.thanksHeading or "Thanks, I'll be in touch shortly!" }}</h1>
      <a href="/" class="button button-primary">{{ page.thanksCtaText or "Home Again" }}</a>
    </div>
  </section>

{% elif page.uri == "contact" %}
  <section class="section wrapper flow" data-size="small">
    {% if page.contactHeading %}
      <h1 class="text-align-center">{{ page.contactHeading }}</h1>
    {% endif %}
    {% if page.contactText %}
      <div class=" flow" data-space="xs">
      {{ page.contactText | markdown | safe }}
      </div>
    {% endif %}
    <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thanks/" data-no-swup class="form">
      <input type="hidden" name="form-name" value="contact" />
      <p class="hide">
        <label>
          Don't fill this in: <input name="bot-field" tabindex="-1" autocomplete="off" />
        </label>
      </p>
      <div class="form__success" data-visible="{{ 'true' if success else 'false' }}">
        Thank you! Your message has been received.
      </div>
      <div class="form__error" data-visible="{{ 'true' if error else 'false' }}">
        Oops! Something went wrong while submitting the form.
      </div>
      <div class="form__row">
        <div class="form__field">
          <label class="form__label" for="name">Name</label>
          <input class="form__input" type="text" name="name" id="name" required />
        </div>
        <div class="form__field">
          <label class="form__label" for="email">Email</label>
          <input class="form__input" type="email" name="email" id="email" required />
        </div>
      </div>
      <div class="form__field">
        <label class="form__label" for="message">Message</label>
        <textarea class="form__input form__textarea" name="message" id="message" required></textarea>
      </div>
      <button class="button button-primary" type="submit">Send</button>
    </form>
  </section>

{% elif page.uri == "services" %}
  {% if page.servicesIntroHeading or page.servicesIntroText or page.servicesIntroImage %}
    {% set title = page.servicesIntroHeading %}
    {% set body = page.servicesIntroText %}
    {% set imageSrc = page.servicesIntroImage %}
    {% set imageAlt = page.servicesIntroHeading %}
    {% set loading = "eager" %}
    {% set ctaText = page.servicesIntroCtaText %}
    {% set ctaLink = page.servicesIntroCtaLink %}
    {% include "components/hero-home.njk" %}
  {% endif %}

  {% if page.servicesWritingHeading or page.servicesWritingText or page.servicesWritingRates %}
    <section class="section wrapper flow | text-align-center" data-space="xs">
      {% if page.servicesWritingHeading %}
        <h2>{{ page.servicesWritingHeading }}</h2>
      {% endif %}
      {% if page.servicesWritingText %}
        <div class="pricing-card__description">{{ page.servicesWritingText | markdown | safe }}</div>
      {% endif %}
      {% if page.servicesWritingRates %}
        <div class="grid" data-layout="3col" style="margin-block-start: var(--space-m);">
          {% for item in page.servicesWritingRates %}
            <article class="card pricing-card">
              <div class="card__body pricing-card__body">
                <p class="pricing-card__price">{{ item.rateprice or item.ratePrice }}</p>
                <p class="pricing-card__desc">{{ item.ratedescription or item.rateDescription }}</p>
              </div>
            </article>
          {% endfor %}
        </div>
        {% if page.servicesWritingRatesNote %}
          <p class="services__rates-note">{{ page.servicesWritingRatesNote }}</p>
        {% endif %}
      {% endif %}
    </section>
  {% endif %}

  {% if page.servicesExpertHeading or page.servicesExpertText or page.servicesPodcastHeading or page.servicesPodcastText %}
    {% set heroBody = "" %}
    {% if page.servicesExpertHeading %}
      {% set heroBody = heroBody + "## " + page.servicesExpertHeading + "\n\n" %}
    {% endif %}
    {% if page.servicesExpertText %}
      {% set heroBody = heroBody + page.servicesExpertText + "\n\n" %}
    {% endif %}
    {% if page.servicesPodcastHeading %}
      {% set heroBody = heroBody + "## " + page.servicesPodcastHeading + "\n\n" %}
    {% endif %}
    {% if page.servicesPodcastText %}
      {% set heroBody = heroBody + page.servicesPodcastText %}
    {% endif %}
    {% set title = "" %}
    {% set body = heroBody %}
    {% set imageSrc = page.servicesExpertPodcastImage %}
    {% set imageAlt = page.servicesExpertHeading if page.servicesExpertHeading else page.servicesPodcastHeading %}
    {% set loading = "lazy" %}
    {% set imageSide = "right" %}
    {% set ctaText = page.servicesPodcastCtaText %}
    {% set ctaLink = page.servicesPodcastCtaLink %}
    {% include "components/hero-home.njk" %}
  {% endif %}

{% else %}
  <div class="wrapper flow prose">
    <h1>{{ page.title }}</h1>
    {{ page.text | markdown | safe }}
  </div>
{% endif %}
