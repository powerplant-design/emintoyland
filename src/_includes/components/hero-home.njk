<section class="hero-hero" data-layout="split" data-image="left">
  <div class="hero-hero__image">
    {% if imageSrc %}
      <img src="{{ imageSrc }}" alt="{{ imageAlt }}" sizes="(min-width: 66rem) 33vw, 100vw" {% if loading == "eager" %}loading="eager"{% endif %}>
    {% endif %}
  </div>
  <div class="hero-hero__content stack" style="--stack-vertical: center;">
    {% if titleTag == "h2" %}
      <h2 class="hero-hero__heading">{{ title }}</h2>
    {% else %}
      <h1 class="hero-hero__heading">{{ title }}</h1>
    {% endif %}
    <div class="hero-hero__text stack">
      {{ body | markdown | safe }}
    </div>
    {% if ctaText and ctaLink %}
      <div class="hero-hero__cta">
        <a href="{{ ctaLink }}" class="button button-primary">{{ ctaText }} →</a>
      </div>
    {% endif %}
  </div>
</section>
