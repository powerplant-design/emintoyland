{% set logoUrl = kirby.settings.siteImages.logoPink.url %}
{% set logoAlt = kirby.settings.siteImages.logoPink.alt %}
{% set navPage = (page.uri | default('home')).split('/')[0] %}
<nav class="navbar navbar--{{ navPage }}" data-state="idle" role="navigation">
  <div class="navbar__inner">
    <a href="/" class="navbar__logo" aria-label="Home">
      {% if logoUrl %}
        <img src="{{ logoUrl }}" alt="{{ logoAlt }}" sizes="130px">
      {% else %}
        <span>Em in Toyland</span>
      {% endif %}
    </a>
    <button class="navbar__toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="navbar__menu">
      <ul class="navbar__list">
        {% set currentUri = page.uri %}
        {% for link in kirby.settings.nav %}
          <li>
            {% set linkSlug = link.href | replace('/', '') %}
            <a href="{{ link.href }}" class="navbar__link{% if linkSlug %} navbar__link--{{ linkSlug }}{% endif %}"
              {% if currentUri == linkSlug or (link.href != '/' and linkSlug and currentUri and linkSlug in currentUri) %}
                aria-current="page"
              {% endif %}>
              {{ link.label }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</nav>
