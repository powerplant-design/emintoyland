{% set logoUrl = kirby.settings.siteImages.logoPink.url %}
{% set logoAlt = kirby.settings.siteImages.logoPink.alt %}
<nav class="navbar" data-state="idle" role="navigation">
  <div class="navbar__inner">
    <a href="/" class="navbar__logo" aria-label="Home">
      {% if logoUrl %}
        <img src="{{ logoUrl }}" alt="{{ logoAlt }}" sizes="130px">
      {% else %}
        <span>Em in Toyland</span>
      {% endif %}
    </a>
    <button class="navbar__toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="navbar__menu">
      <ul class="navbar__list">
        {% set currentUri = page.uri %}
        {# <li><a href="/" class="navbar__link"{% if currentUri == 'home' %} aria-current="page"{% endif %}>Home</a></li> #}
        <li><a href="/about/" class="navbar__link"{% if currentUri == 'about' %} aria-current="page"{% endif %}>About</a></li>
        <li><a href="/work/" class="navbar__link"{% if currentUri == 'work' or 'work/' in currentUri %} aria-current="page"{% endif %}>Work</a></li>
        <li><a href="/blog/" class="navbar__link"{% if currentUri == 'blog' or 'blog/' in currentUri %} aria-current="page"{% endif %}>Blog</a></li>
        <li><a href="/contact/" class="navbar__link"{% if currentUri == 'contact' %} aria-current="page"{% endif %}>Contact</a></li>
      </ul>
    </div>
  </div>
</nav>
