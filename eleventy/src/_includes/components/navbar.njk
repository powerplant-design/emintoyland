<nav class="navbar" data-state="idle" role="navigation">
  <div class="navbar__inner  wrapper">
    <a href="/" class="navbar__logo" aria-label="Home">
      <img src="/images/eit-logo-shadow.png" alt="Em in Toyland" width="130" height="auto">
    </a>
    <button class="navbar__toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="navbar__menu">
      <ul class="navbar__list">
        {% set currentUri = page.uri %}
        <li><a href="/" class="navbar__link"{% if currentUri == 'home' %} aria-current="page"{% endif %}>Home</a></li>
        <li><a href="/about/" class="navbar__link"{% if currentUri == 'about' %} aria-current="page"{% endif %}>About</a></li>
        <li><a href="/work/" class="navbar__link"{% if currentUri == 'work' or 'work/' in currentUri %} aria-current="page"{% endif %}>Work</a></li>
        <li><a href="/contact/" class="navbar__link"{% if currentUri == 'contact' %} aria-current="page"{% endif %}>Contact</a></li>
      </ul>
    </div>
  </div>
</nav>

<script>
  (function() {
    var navbar = document.querySelector('.navbar');
    var toggle = document.querySelector('.navbar__toggle');
    var menu = document.querySelector('.navbar__menu');

    if (!toggle || !navbar) return;

    // Scroll effect
    function onScroll() {
      navbar.classList.toggle('scrolled', window.scrollY > 50);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Toggle mobile menu
    toggle.addEventListener('click', function() {
      var isActive = navbar.getAttribute('data-state') === 'active';
      navbar.setAttribute('data-state', isActive ? 'idle' : 'active');
      toggle.setAttribute('aria-expanded', !isActive);
      toggle.classList.toggle('is-active', !isActive);
    });

    // Close menu on link click
    if (menu) {
      menu.addEventListener('click', function(e) {
        if (e.target.closest('.navbar__link')) {
          navbar.setAttribute('data-state', 'idle');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.classList.remove('is-active');
        }
      });
    }

    // Close menu on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && navbar.getAttribute('data-state') === 'active') {
        navbar.setAttribute('data-state', 'idle');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.classList.remove('is-active');
      }
    });
  })();
</script>
